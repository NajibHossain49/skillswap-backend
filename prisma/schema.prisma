// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MENTOR
  LEARNER
}

enum SessionStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum NotificationType {
  SESSION_BOOKED
  SESSION_CANCELLED
  SESSION_REMINDER
  SESSION_COMPLETED
  FEEDBACK_RECEIVED
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  MENTOR_APPROVED
  SYSTEM
}

enum BookingRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum CreditTxnType {
  SIGNUP_BONUS
  EARNED
  SPENT
  REFUND
  ADMIN_ADJUSTMENT
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MentorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  NO_SHOW
  FRAUD
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  name                String
  bio                 String?
  role                Role      @default(LEARNER)
  isActive            Boolean   @default(true)
  tokenVersion        Int       @default(0)
  isEmailVerified     Boolean   @default(false)
  avatarUrl           String?
  deletedAt           DateTime?
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  creditBalance       Int       @default(3) // 3 free starter credits
  ratingAvg           Float     @default(0) // denormalized, recomputed on new feedback
  ratingCount         Int       @default(0)
  totalSessionsTaught Int       @default(0)
  headline            String? // "Full-stack dev · 5 yrs"
  location            String?
  mentorStatus        MentorStatus @default(NONE)
  mentorExperience    String? // free-text pitch submitted with a mentor application
  mentorLinkedinUrl   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  mentorSessions          Session[]           @relation("MentorSessions")
  learnerSessions         Session[]           @relation("LearnerSessions")
  createdSkills           Skill[]             @relation("SkillCreator")
  refreshTokens           RefreshToken[]
  verificationTokens      VerificationToken[]
  notifications           Notification[]
  feedbacks               Feedback[]          @relation("LearnerFeedback")
  availabilities          Availability[]      @relation("MentorAvailability")
  sentBookingRequests     BookingRequest[]    @relation("LearnerBookingRequests")
  receivedBookingRequests BookingRequest[]    @relation("MentorBookingRequests")
  creditTransactions      CreditTransaction[]

  @@index([email])
  @@index([role, isActive])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  familyId  String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("verification_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Skill {
  id          String     @id @default(uuid())
  title       String
  description String
  category    String
  level       SkillLevel @default(BEGINNER)
  tags        String[]   @default([])
  creditCost  Int        @default(1)
  createdById String
  isActive    Boolean    @default(true)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy       User             @relation("SkillCreator", fields: [createdById], references: [id])
  sessions        Session[]
  bookingRequests BookingRequest[]

  @@index([category])
  @@index([createdById])
  @@map("skills")
}

model Session {
  id           String        @id @default(uuid())
  mentorId     String
  learnerId    String?
  skillId      String
  title        String
  description  String?
  scheduledAt  DateTime
  duration     Int           // minutes
  status       SessionStatus @default(PENDING)
  meetingLink  String?
  cancelReason String?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  mentor         User            @relation("MentorSessions", fields: [mentorId], references: [id])
  learner        User?           @relation("LearnerSessions", fields: [learnerId], references: [id])
  skill          Skill           @relation(fields: [skillId], references: [id])
  feedback       Feedback?
  bookingRequest BookingRequest?

  @@index([mentorId, status])
  @@index([learnerId, status])
  @@index([skillId])
  @@index([scheduledAt])
  @@map("sessions")
}

model CreditTransaction {
  id           String        @id @default(uuid())
  userId       String
  amount       Int // positive = credit, negative = debit
  balanceAfter Int
  type         CreditTxnType
  sessionId    String?
  description  String
  createdAt    DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String?
  sessionId      String?
  skillId        String?
  reason         ReportReason
  details        String
  status         ReportStatus @default(OPEN)
  adminNote      String?
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([status, createdAt])
  @@map("reports")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String // "user.deactivate", "user.role_change", "report.resolve"
  entity    String // "User" | "Session" | "Skill"
  entityId  String
  before    Json?
  after     Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Availability {
  id        String   @id @default(uuid())
  mentorId  String
  dayOfWeek Int // 0=Sunday .. 6=Saturday
  startTime String // "14:00" (24h, mentor's local time)
  endTime   String // "17:00"
  timezone  String   @default("Asia/Dhaka")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  mentor User @relation("MentorAvailability", fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId, dayOfWeek])
  @@map("availabilities")
}

model BookingRequest {
  id           String               @id @default(uuid())
  learnerId    String
  mentorId     String
  skillId      String
  message      String?
  proposedAt   DateTime
  duration     Int // minutes
  status       BookingRequestStatus @default(PENDING)
  rejectReason String?
  sessionId    String?              @unique // set when ACCEPTED → the created Session
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  learner User     @relation("LearnerBookingRequests", fields: [learnerId], references: [id], onDelete: Cascade)
  mentor  User     @relation("MentorBookingRequests", fields: [mentorId], references: [id], onDelete: Cascade)
  skill   Skill    @relation(fields: [skillId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([mentorId, status])
  @@index([learnerId, status])
  @@map("booking_requests")
}

model Feedback {
  id        String   @id @default(uuid())
  sessionId String   @unique
  learnerId String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  learner User    @relation("LearnerFeedback", fields: [learnerId], references: [id])

  @@map("feedbacks")
}
