{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma migrate deploy && tsc",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/api/internal/cron/cleanupExpiredTokens", "schedule": "0 3 * * *" },
    { "path": "/api/internal/cron/autoCompleteSessions", "schedule": "0 4 * * *" }
  ]
}