# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT (secrets must be at least 32 characters)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated allowlist of origins)
CORS_ORIGIN=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Application
APP_URL=http://localhost:3001

# Security
BCRYPT_ROUNDS=12

# Scheduled jobs
# Shared secret for POST /api/internal/cron/:job (sent as x-cron-secret / Bearer)
CRON_SECRET=
# Run node-cron in-process. Set to "false" on serverless (Vercel) and trigger via HTTP.
ENABLE_CRON=true

# API docs (Swagger UI at /api/docs)
ENABLE_DOCS=true
# Optional HTTP Basic Auth for the docs (set both to enable)
DOCS_USER=
DOCS_PASSWORD=
