# Server
NODE_ENV=development
PORT=3000

# Database
# Runtime connection. On Neon/serverless use the POOLED endpoint (host contains
# "-pooler") and append ?sslmode=require&connection_limit=1
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Non-pooled endpoint used only by `prisma migrate deploy`. On Neon this is the
# host WITHOUT "-pooler". Optional locally (falls back to DATABASE_URL).
DIRECT_URL=

# JWT (secrets must be at least 32 characters)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated allowlist of origins). In production must NOT be unset,
# "*", or contain localhost — the app refuses to boot otherwise.
CORS_ORIGIN=http://localhost:3000

# Rate limiter (Upstash Redis REST). Optional locally (falls back to an in-memory
# store); REQUIRED in production — on serverless the in-memory store is per-lambda
# and resets each invocation, silently disabling rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Application
APP_URL=http://localhost:3001

# Security
BCRYPT_ROUNDS=12

# Scheduled jobs
# Shared secret for POST /api/internal/cron/:job (sent as x-cron-secret / Bearer)
CRON_SECRET=
# Run node-cron in-process. Set to "false" on serverless (Vercel) and trigger via HTTP.
ENABLE_CRON=true

# API docs (Swagger UI at /api/docs)
ENABLE_DOCS=true
# Optional HTTP Basic Auth for the docs (set both to enable)
DOCS_USER=
DOCS_PASSWORD=
